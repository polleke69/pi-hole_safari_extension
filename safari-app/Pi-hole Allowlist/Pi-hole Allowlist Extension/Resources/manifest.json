{
  "manifest_version": 3,
  "name": "Pi-hole Allowlist",
  "version": "1.0.0",
  "description": "Voeg het actieve tabblad-domein toe aan de Pi-hole allowlist (v6 API).",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_title": "Pi-hole: domein allowlisten",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html"
  }
}
